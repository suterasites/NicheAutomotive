<script>
  (function () {
    var parents = document.querySelectorAll('.nmm-parent');
    for (var i = 0; i < parents.length; i++) {
      (function (parent) {
        if (parent.dataset.nmmInit) return;
        parent.dataset.nmmInit = '1';
        var trigger = parent.querySelector('.nmm-trigger');
        var timer;
        function open() {
          clearTimeout(timer);
          parent.classList.add('is-open');
          if (trigger) trigger.setAttribute('aria-expanded', 'true');
        }
        function scheduleClose() {
          clearTimeout(timer);
          timer = setTimeout(function () {
            parent.classList.remove('is-open');
            if (trigger) trigger.setAttribute('aria-expanded', 'false');
          }, 220);
        }
        parent.addEventListener('mouseenter', open);
        parent.addEventListener('mouseleave', scheduleClose);
        if (trigger && trigger.tagName !== 'A') {
          trigger.addEventListener('click', function (e) {
            e.preventDefault();
            parent.classList.contains('is-open') ? scheduleClose() : open();
          });
        }
      })(parents[i]);
    }
  })();
</script>
