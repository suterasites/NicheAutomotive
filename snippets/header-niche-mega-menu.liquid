{% comment %}
  Niche Automotive - self-contained hardcoded mega menu. (build 2 - hover)
  Shows the full planned site structure so Gorgi can see every page the site will include,
  without needing a Shopify Navigation menu built in admin.
  Fully self-contained: opens on HOVER (and keyboard focus), positions its own full-width
  panel anchored to the relative .header-wrapper, and does NOT depend on Dawn's
  component-mega-menu.css (which only loads when menu_type_desktop == 'mega').
  All bespoke styling is scoped to .nmm-*.
{% endcomment %}

{%- style -%}
  .nmm-parent { position: static; }
  .header__inline-menu .header__menu-item { font-size: 1.6rem; }

  .nmm-trigger {
    -webkit-appearance: none; appearance: none;
    background: transparent; border: 0; margin: 0; cursor: pointer;
    padding-right: 2.4rem;
  }
  .nmm-trigger .icon-caret {
    height: 0.6rem; width: auto; margin-left: 0.5rem;
    transition: transform 0.2s ease;
  }
  .nmm-parent.is-open .nmm-trigger .icon-caret,
  .nmm-parent:focus-within .nmm-trigger .icon-caret { transform: rotate(180deg); }
  .nmm-parent.is-open .nmm-trigger span,
  .nmm-parent:focus-within .nmm-trigger span { text-decoration: underline; text-underline-offset: 0.3rem; }

  /* Shop Parts: accented as the store entry point so it's the obvious place to buy */
  .header__inline-menu .nmm-trigger--parts { color: #e11b22; }
  .header__inline-menu .nmm-trigger--parts span { font-weight: 700; }
  .header__inline-menu .nmm-trigger--parts:hover { color: #c3141b; }

  /* full-width panel anchored to the relative .header-wrapper */
  .nmm-content {
    position: absolute; left: 0; right: 0; top: 100%;
    z-index: 4;
    background: #0e0e10;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 2.6rem 0 3rem;
    opacity: 0; visibility: hidden;
    transform: translateY(-0.8rem);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0.2s;
    pointer-events: none;
  }
  .nmm-parent.is-open > .nmm-content,
  .nmm-parent:focus-within > .nmm-content {
    opacity: 1; visibility: visible; transform: translateY(0);
    pointer-events: auto;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  /* transparent bridge so the cursor can cross the header gap without closing */
  .nmm-content::after { content: ""; position: absolute; left: 0; right: 0; top: -3rem; height: 3rem; }
  /* subtle red glow, top-right */
  .nmm-content::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(60% 120% at 88% -20%, rgba(225,27,34,0.18) 0%, rgba(225,27,34,0) 55%);
  }

  .nmm-inner {
    position: relative; z-index: 1;
    max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem;
    display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: stretch;
  }
  .nmm-eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.12rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
    color: #ff5a60; margin: 0 0 1.4rem;
  }
  .nmm-eyebrow::before { content: ""; width: 26px; height: 2px; background: #e11b22; }
  .nmm-grid { display: grid; gap: 0.5rem 1.4rem; list-style: none; margin: 0; padding: 0; }
  .nmm-grid--svc { grid-template-columns: repeat(3, 1fr); }
  .nmm-grid--parts { grid-template-columns: repeat(4, 1fr); }
  .nmm-link {
    display: flex; align-items: flex-start; gap: 0.85rem;
    padding: 0.7rem 0.8rem; border-radius: 10px; text-decoration: none;
    transition: background 0.15s ease;
  }
  .nmm-link:hover { background: rgba(255,255,255,0.05); }
  .nmm-ico {
    flex: 0 0 auto; width: 38px; height: 38px; border-radius: 9px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(225,27,34,0.12); transition: background 0.15s ease;
  }
  .nmm-link:hover .nmm-ico { background: #e11b22; }
  .nmm-ico svg { width: 19px; height: 19px; fill: none; stroke: #ff5a60; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; transition: stroke 0.15s ease; }
  .nmm-link:hover .nmm-ico svg { stroke: #fff; }
  .nmm-txt { display: flex; flex-direction: column; gap: 0.15rem; padding-top: 0.1rem; }
  .nmm-t { font-family: var(--font-heading-family); font-weight: 600; font-size: 1.52rem; color: #fff; letter-spacing: 0.01em; line-height: 1.15; }
  .nmm-d { font-size: 1.24rem; line-height: 1.35; color: rgba(255,255,255,0.55); }
  .nmm-grid--parts .nmm-link { align-items: center; }
  .nmm-grid--parts .nmm-t { font-size: 1.47rem; }

  /* right rail card */
  .nmm-rail { display: flex; }
  .nmm-card {
    display: flex; flex-direction: column; justify-content: center;
    width: 100%; border-radius: 14px; padding: 1.9rem 1.7rem;
    background: linear-gradient(160deg, #e11b22 0%, #b3141a 100%);
    box-shadow: 0 20px 40px rgba(225,27,34,0.22);
  }
  .nmm-card--dark { background: #17171b; border: 1px solid rgba(255,255,255,0.1); box-shadow: none; }
  .nmm-card-label { text-transform: uppercase; letter-spacing: 0.14em; font-size: 1.05rem; font-weight: 600; color: rgba(255,255,255,0.85); margin: 0 0 0.5rem; }
  .nmm-card h4 { font-family: var(--font-heading-family); text-transform: uppercase; font-weight: 700; font-size: 2.09rem; line-height: 1.05; color: #fff; margin: 0 0 0.9rem; letter-spacing: 0.01em; }
  .nmm-card p { font-size: 1.32rem; line-height: 1.45; color: rgba(255,255,255,0.8); margin: 0 0 1.2rem; }
  .nmm-phone { display: block; font-family: var(--font-heading-family); font-weight: 700; font-size: 2.33rem; color: #fff; text-decoration: none; margin: 0 0 1.1rem; letter-spacing: 0.01em; }
  .nmm-phone:hover { text-decoration: underline; }
  .nmm-btn { display: inline-flex; align-items: center; justify-content: center; align-self: flex-start; background: #fff; color: #111; font-weight: 700; font-size: 1.4rem; text-decoration: none; padding: 0.75rem 1.4rem; border-radius: 3px; transition: transform 0.15s ease; }
  .nmm-btn:hover { transform: translateY(-2px); }
  .nmm-card--dark .nmm-btn { background: #e11b22; color: #fff; }

  @media (max-width: 1100px) {
    .nmm-inner { grid-template-columns: 1fr; gap: 2rem; }
    .nmm-rail { display: none; }
    .nmm-grid--svc { grid-template-columns: repeat(2, 1fr); }
  }
{%- endstyle -%}

