{%- comment -%}
  Niche Automotive - Services (v4, image cards).
  Two-column header (label + big heading | description + links), then a row of 5
  photo cards (image + title + arrow) with a "View All Services" link. Niche red palette.
  The 5 cards are hardcoded with baked photo assets so the section renders reliably
  regardless of stored customiser settings. All CSS scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-svc-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: #0f0f0f;
  }
  .n-svc-{{ section.id }} .n-svc__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }

  /* header */
  .n-svc-{{ section.id }} .n-svc__head {
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 2.5rem 3rem; align-items: end; margin: 0 0 2.8rem;
  }
  .n-svc-{{ section.id }} .n-svc__kicker { font-size: 1.35rem; font-weight: 600; color: #4a4a4e; margin: 0 0 1rem; }
  .n-svc-{{ section.id }} .n-svc__kicker span { color: #e11b22; }
  .n-svc-{{ section.id }} .n-svc__title {
    font-family: var(--font-heading-family); color: #0f0f0f;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.005em;
    font-size: clamp(3rem, 5.4vw, 5rem); line-height: 0.95; margin: 0;
  }
  .n-svc-{{ section.id }} .n-svc__aside { padding-bottom: 0.4rem; }
  .n-svc-{{ section.id }} .n-svc__aside p { margin: 0 0 1.2rem; font-size: 1.55rem; line-height: 1.6; color: #4a4a4e; max-width: 40ch; }
  .n-svc-{{ section.id }} .n-svc__links { display: flex; flex-wrap: wrap; gap: 1.2rem 2.2rem; }
  .n-svc-{{ section.id }} .n-svc__link {
    display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none;
    color: #e11b22; font-weight: 700; font-size: 1.5rem; transition: gap 0.15s ease;
  }
  .n-svc-{{ section.id }} .n-svc__link:hover { gap: 0.75rem; }
  .n-svc-{{ section.id }} .n-svc__link svg { width: 16px; height: 16px; }

  /* cards */
  .n-svc-{{ section.id }} .n-svc__row { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 1.1rem; }
  .n-svc-{{ section.id }} .n-svc__card {
    position: relative; display: block; aspect-ratio: 3 / 4; border-radius: 14px; overflow: hidden;
    text-decoration: none; background: #161616;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .n-svc-{{ section.id }} .n-svc__card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(15,15,15,0.22); }
  .n-svc-{{ section.id }} .n-svc__card img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .n-svc-{{ section.id }} .n-svc__card:hover img { transform: scale(1.06); }
  .n-svc-{{ section.id }} .n-svc__card::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(15,15,15,0) 42%, rgba(15,15,15,0.55) 72%, rgba(15,15,15,0.9) 100%);
  }
  .n-svc-{{ section.id }} .n-svc__card-title {
    position: absolute; left: 1.1rem; right: 3.8rem; bottom: 1.2rem; z-index: 2; color: #fff;
    font-family: var(--font-heading-family); font-weight: 600; text-transform: uppercase;
    font-size: 1.55rem; line-height: 1.14; letter-spacing: 0.02em;
  }
  .n-svc-{{ section.id }} .n-svc__card-btn {
    position: absolute; right: 1rem; bottom: 1rem; z-index: 2;
    width: 42px; height: 42px; border-radius: 50%; display: grid; place-items: center;
    background: rgba(255,255,255,0.16); color: #fff; transition: background 0.18s ease, transform 0.18s ease;
  }
  .n-svc-{{ section.id }} .n-svc__card:first-child .n-svc__card-btn { background: #e11b22; }
  .n-svc-{{ section.id }} .n-svc__card:hover .n-svc__card-btn { background: #e11b22; transform: translateY(-2px); }
  .n-svc-{{ section.id }} .n-svc__card-btn svg { width: 18px; height: 18px; }

  @media (max-width: 900px) {
    .n-svc-{{ section.id }} .n-svc__head { grid-template-columns: 1fr; align-items: start; gap: 1.4rem; }
    .n-svc-{{ section.id }} .n-svc__wrap { padding: 0 2rem; }
    .n-svc-{{ section.id }} .n-svc__row {
      grid-auto-flow: column; grid-template-columns: none; grid-auto-columns: minmax(210px, 62%);
      overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
      margin: 0 -2rem; padding: 0 2rem 1rem; gap: 0.9rem;
    }
    .n-svc-{{ section.id }} .n-svc__card { scroll-snap-align: start; }
  }
{%- endstyle -%}

<div class="n-svc-{{ section.id }}">
  <div class="n-svc__wrap">

    <div class="n-svc__head">
      <div>
        {%- if section.settings.kicker != blank -%}<p class="n-svc__kicker"><span>/</span> {{ section.settings.kicker | escape }}</p>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2 class="n-svc__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      </div>
      <div class="n-svc__aside">
        {%- if section.settings.subtitle != blank -%}<p>{{ section.settings.subtitle | escape }}</p>{%- endif -%}
        <div class="n-svc__links">
          {%- if section.settings.viewall_label != blank -%}
            <a class="n-svc__link" href="{{ section.settings.viewall_link | default: '/pages/services' }}">{{ section.settings.viewall_label | escape }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></a>
          {%- endif -%}
          {%- if section.settings.call_label != blank and section.settings.phone != blank -%}
            <a class="n-svc__link" href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.call_label | escape }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="n-svc__row">
      {%- assign arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>' -%}

      <a class="n-svc__card" href="/pages/log-book-servicing">
        <img src="{{ 'niche-svc-logbook.jpg' | asset_url }}" alt="Log book servicing at Niche Automotive" loading="lazy" width="820" height="820">
        <span class="n-svc__card-title">Log Book Servicing</span>
        <span class="n-svc__card-btn">{{ arrow }}</span>
      </a>

      <a class="n-svc__card" href="/pages/mechanical-repairs">
        <img src="{{ 'niche-svc-repairs.jpg' | asset_url }}" alt="Mechanical repairs at Niche Automotive" loading="lazy" width="820" height="820">
        <span class="n-svc__card-title">Mechanical Repairs</span>
        <span class="n-svc__card-btn">{{ arrow }}</span>
      </a>

      <a class="n-svc__card" href="/pages/performance-upgrades">
        <img src="{{ 'niche-svc-performance.jpg' | asset_url }}" alt="Performance upgrades at Niche Automotive" loading="lazy" width="820" height="547">
        <span class="n-svc__card-title">Performance Upgrades</span>
        <span class="n-svc__card-btn">{{ arrow }}</span>
      </a>

      <a class="n-svc__card" href="/pages/engine-builds">
        <img src="{{ 'niche-svc-engine.jpg' | asset_url }}" alt="Engine builds and rebuilds at Niche Automotive" loading="lazy" width="820" height="820">
        <span class="n-svc__card-title">Engine Builds &amp; Rebuilds</span>
        <span class="n-svc__card-btn">{{ arrow }}</span>
      </a>

      <a class="n-svc__card" href="/pages/pre-purchase-inspections">
        <img src="{{ 'niche-svc-inspection.jpg' | asset_url }}" alt="Pre-purchase inspections at Niche Automotive" loading="lazy" width="820" height="820">
        <span class="n-svc__card-title">Pre-Purchase Inspections</span>
        <span class="n-svc__card-btn">{{ arrow }}</span>
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Niche Services",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Services We Offer" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Full-Service Workshop" },
    { "type": "text", "id": "subtitle", "label": "Description", "default": "From routine servicing to full rebuilds, we cover all makes and models with honest work and fair, upfront pricing." },
    { "type": "text", "id": "viewall_label", "label": "View-all label", "default": "View All Services" },
    { "type": "url", "id": "viewall_link", "label": "View-all link" },
    { "type": "text", "id": "call_label", "label": "Call label", "default": "Call the Workshop" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "0411 019 935" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F6F8" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 84 }
  ],
  "blocks": [
    { "type": "service", "name": "Service (legacy, unused)", "settings": [
      { "type": "text", "id": "title", "label": "Service name" }
    ] }
  ],
  "presets": [ { "name": "Niche Services" } ]
}
{% endschema %}
