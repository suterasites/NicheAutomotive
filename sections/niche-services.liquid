{%- comment -%}
  Niche Automotive - Services grid (v3).
  Self-contained, Dawn-compatible. Real inline SVG icons per service, hover-lift cards,
  red accent reveal. All CSS scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-svc-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .n-svc-{{ section.id }} .n-svc__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }
  .n-svc-{{ section.id }} .n-svc__head { max-width: 52rem; margin: 0 0 2.6rem; }
  .n-svc-{{ section.id }} .n-svc__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.74rem; letter-spacing: 0.22em; text-transform: uppercase;
    font-weight: 600; color: #e11b22; margin: 0 0 0.9rem;
  }
  .n-svc-{{ section.id }} .n-svc__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-svc-{{ section.id }} .n-svc__title {
    font-family: var(--font-heading-family);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.01em;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.05; margin: 0 0 0.6rem;
  }
  .n-svc-{{ section.id }} .n-svc__sub { margin: 0; font-size: 1.05rem; opacity: 0.72; line-height: 1.5; }
  .n-svc-{{ section.id }} .n-svc__grid {
    display: grid; grid-template-columns: repeat({{ section.settings.columns }}, minmax(0, 1fr)); gap: 1.25rem;
  }
  .n-svc-{{ section.id }} .n-svc__item {
    position: relative; background: {{ section.settings.card_color }};
    border: 1px solid rgba(15,15,15,0.09); border-radius: 14px;
    padding: 1.8rem 1.7rem; overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .n-svc-{{ section.id }} .n-svc__item::before {
    content: ""; position: absolute; top: 0; left: 0; height: 3px; width: 0; background: #e11b22; transition: width 0.25s ease;
  }
  .n-svc-{{ section.id }} .n-svc__item:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(15,15,15,0.12); border-color: rgba(225,27,34,0.35); }
  .n-svc-{{ section.id }} .n-svc__item:hover::before { width: 100%; }
  .n-svc-{{ section.id }} .n-svc__icon {
    width: 52px; height: 52px; border-radius: 12px; margin-bottom: 1.15rem;
    display: grid; place-items: center;
    background: rgba(225,27,34,0.10); color: #e11b22;
  }
  .n-svc-{{ section.id }} .n-svc__icon svg { width: 26px; height: 26px; stroke: currentColor; fill: none; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
  .n-svc-{{ section.id }} .n-svc__item h3 {
    font-family: var(--font-heading-family);
    font-size: 1.16rem; text-transform: uppercase; letter-spacing: 0.02em;
    margin: 0 0 0.45rem; line-height: 1.15;
  }
  .n-svc-{{ section.id }} .n-svc__item p { margin: 0; font-size: 0.96rem; line-height: 1.5; opacity: 0.72; }
  @media (max-width: 990px) { .n-svc-{{ section.id }} .n-svc__grid { grid-template-columns: repeat(2, minmax(0,1fr)); } .n-svc-{{ section.id }} .n-svc__wrap { padding: 0 2rem; } }
  @media (max-width: 600px) { .n-svc-{{ section.id }} .n-svc__grid { grid-template-columns: 1fr; } }
{%- endstyle -%}

<div class="n-svc-{{ section.id }}">
  <div class="n-svc__wrap">
    <div class="n-svc__head">
      {%- if section.settings.eyebrow != blank -%}<span class="n-svc__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
      {%- if section.settings.title != blank -%}<h2 class="n-svc__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      {%- if section.settings.subtitle != blank -%}<p class="n-svc__sub">{{ section.settings.subtitle | escape }}</p>{%- endif -%}
    </div>

    <div class="n-svc__grid">
      {%- for block in section.blocks -%}
        <div class="n-svc__item" {{ block.shopify_attributes }}>
          <div class="n-svc__icon">
            {%- case block.settings.icon -%}
              {%- when 'calendar' -%}<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="8.5 15.5 11 18 15.5 13.5"/></svg>
              {%- when 'tag' -%}<svg viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              {%- when 'search' -%}<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              {%- when 'wrench' -%}<svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              {%- when 'gauge' -%}<svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              {%- when 'engine' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              {%- when 'tyre' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="3" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="21"/><line x1="3" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="21" y2="12"/></svg>
              {%- when 'target' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/></svg>
              {%- when 'shield' -%}<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- else -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {%- endcase -%}
          </div>
          <h3>{{ block.settings.title | escape }}</h3>
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text | escape }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Niche Services",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What We Do" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Full-Service Workshop" },
    { "type": "text", "id": "subtitle", "label": "Subheading", "default": "Honest, high-quality work across all makes and models, with clear pricing and no surprises." },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columns (desktop)", "default": 3 },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F6F8" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#0F0F0F" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "wrench", "options": [
          { "value": "calendar", "label": "Calendar (servicing)" },
          { "value": "tag", "label": "Tag (pricing)" },
          { "value": "search", "label": "Magnifier (inspection)" },
          { "value": "wrench", "label": "Wrench (repairs)" },
          { "value": "gauge", "label": "Gauge (performance)" },
          { "value": "engine", "label": "Cog (engine)" },
          { "value": "tyre", "label": "Tyre (wheels)" },
          { "value": "target", "label": "Target (diagnostics)" },
          { "value": "shield", "label": "Shield (safety)" }
        ] },
        { "type": "text", "id": "title", "label": "Service name", "default": "Service" },
        { "type": "textarea", "id": "text", "label": "Short description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Niche Services",
      "blocks": [
        { "type": "service", "settings": { "icon": "calendar", "title": "Log Book Servicing", "text": "Manufacturer-schedule servicing that keeps your warranty intact." } },
        { "type": "service", "settings": { "icon": "tag", "title": "Fixed Price Servicing", "text": "Clear, upfront pricing with no surprises." } },
        { "type": "service", "settings": { "icon": "search", "title": "Pre-Purchase Inspections", "text": "Know exactly what you are buying before you commit." } },
        { "type": "service", "settings": { "icon": "wrench", "title": "Mechanical Repairs", "text": "Diagnosis and repairs across all makes and models." } },
        { "type": "service", "settings": { "icon": "gauge", "title": "Performance Upgrades", "text": "Get more out of your car with the right upgrades." } },
        { "type": "service", "settings": { "icon": "engine", "title": "Engine Builds & Rebuilds", "text": "Full engine builds and rebuilds done right." } },
        { "type": "service", "settings": { "icon": "tyre", "title": "Wheels & Tyres", "text": "Fitting, balancing and replacement." } },
        { "type": "service", "settings": { "icon": "target", "title": "Diagnostic Scans", "text": "Pinpoint faults fast with proper diagnostic equipment." } },
        { "type": "service", "settings": { "icon": "shield", "title": "Brakes, Suspension & More", "text": "Brake, suspension, battery and cooling system services." } }
      ]
    }
  ]
}
{% endschema %}
