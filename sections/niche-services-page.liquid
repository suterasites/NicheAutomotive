{%- comment -%}
  Niche Automotive - Services page body. (build 1)
  Core workshop services as alternating image/content feature rows (editable blocks,
  each with a baked fallback photo), followed by a "more in the workshop" support grid
  (hardcoded so it renders reliably) and a slim booking strip. Niche red palette.
  All CSS scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-svp-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }}; color: #3a3a3d;
  }
  .n-svp-{{ section.id }} .n-svp__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }

  /* intro */
  .n-svp-{{ section.id }} .n-svp__intro {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 3rem; align-items: end; margin: 0 0 3.4rem;
  }
  .n-svp-{{ section.id }} .n-svp__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem; font-size: 1.18rem; letter-spacing: 0.22em;
    text-transform: uppercase; font-weight: 600; color: #e11b22; margin: 0 0 1rem;
  }
  .n-svp-{{ section.id }} .n-svp__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-svp-{{ section.id }} .n-svp__title {
    font-family: var(--font-heading-family); color: #0f0f0f; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.005em; font-size: clamp(2.4rem, 4.4vw, 3.6rem); line-height: 1.0; margin: 0;
  }
  .n-svp-{{ section.id }} .n-svp__lead { font-size: 1.6rem; line-height: 1.62; color: #4a4a4e; margin: 0; max-width: 52ch; }

  /* feature rows */
  .n-svp-{{ section.id }} .n-svp__rows { display: flex; flex-direction: column; gap: clamp(3.2rem, 6vw, 5.5rem); }
  .n-svp-{{ section.id }} .n-svp__row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3.4rem; align-items: center;
  }
  .n-svp-{{ section.id }} .n-svp__row--flip .n-svp__media { order: 2; }
  .n-svp-{{ section.id }} .n-svp__media { position: relative; }
  .n-svp-{{ section.id }} .n-svp__media-img {
    position: relative; z-index: 1; border-radius: 16px; overflow: hidden; aspect-ratio: 4 / 3;
    box-shadow: 0 26px 54px rgba(0,0,0,0.16);
  }
  .n-svp-{{ section.id }} .n-svp__media-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .n-svp-{{ section.id }} .n-svp__media::before {
    content: ""; position: absolute; z-index: 0; width: 44%; height: 46%; border-radius: 14px;
    top: -16px; left: -16px; background: linear-gradient(135deg, #e11b22 0%, #a5121a 100%);
  }
  .n-svp-{{ section.id }} .n-svp__row--flip .n-svp__media::before { left: auto; right: -16px; }
  .n-svp-{{ section.id }} .n-svp__num {
    display: inline-block; font-family: var(--font-heading-family); font-weight: 700; font-size: 1.3rem;
    letter-spacing: 0.14em; color: #e11b22; margin: 0 0 0.7rem;
  }
  .n-svp-{{ section.id }} .n-svp__h {
    font-family: var(--font-heading-family); color: #0f0f0f; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.01em; font-size: clamp(2rem, 3.4vw, 2.7rem); line-height: 1.05; margin: 0 0 1rem;
  }
  .n-svp-{{ section.id }} .n-svp__p { font-size: 1.56rem; line-height: 1.62; color: #4a4a4e; margin: 0 0 1.3rem; max-width: 50ch; }
  .n-svp-{{ section.id }} .n-svp__list { list-style: none; margin: 0 0 1.6rem; padding: 0; display: grid; gap: 0.6rem; }
  .n-svp-{{ section.id }} .n-svp__list li { display: flex; align-items: flex-start; gap: 0.6rem; font-weight: 600; font-size: 1.48rem; color: #1c1c1f; }
  .n-svp-{{ section.id }} .n-svp__list svg { flex: 0 0 auto; width: 18px; height: 18px; margin-top: 2px; color: #e11b22; }
  .n-svp-{{ section.id }} .n-svp__cta {
    display: inline-flex; align-items: center; gap: 0.45rem; text-decoration: none; color: #e11b22;
    font-weight: 700; font-size: 1.5rem; transition: gap 0.15s ease;
  }
  .n-svp-{{ section.id }} .n-svp__cta:hover { gap: 0.8rem; }
  .n-svp-{{ section.id }} .n-svp__cta svg { width: 16px; height: 16px; }

  /* support grid */
  .n-svp-{{ section.id }} .n-svp__more { margin-top: clamp(4rem, 8vw, 6.5rem); }
  .n-svp-{{ section.id }} .n-svp__more-head { text-align: center; margin: 0 0 2.6rem; }
  .n-svp-{{ section.id }} .n-svp__more-head h2 {
    font-family: var(--font-heading-family); color: #0f0f0f; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.01em; font-size: clamp(1.9rem, 3.4vw, 2.6rem); line-height: 1.05; margin: 0.8rem 0 0;
  }
  .n-svp-{{ section.id }} .n-svp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .n-svp-{{ section.id }} .n-svp__cell {
    background: #fff; border: 1px solid #ececef; border-radius: 14px; padding: 1.7rem 1.6rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .n-svp-{{ section.id }} .n-svp__cell:hover { transform: translateY(-4px); box-shadow: 0 18px 38px rgba(15,15,15,0.1); border-color: #fff; }
  .n-svp-{{ section.id }} .n-svp__cell-ico {
    width: 46px; height: 46px; border-radius: 11px; display: grid; place-items: center; margin: 0 0 1.1rem;
    background: rgba(225,27,34,0.1); color: #e11b22;
  }
  .n-svp-{{ section.id }} .n-svp__cell-ico svg { width: 24px; height: 24px; }
  .n-svp-{{ section.id }} .n-svp__cell h3 {
    font-family: var(--font-heading-family); color: #0f0f0f; font-weight: 700; text-transform: uppercase;
    font-size: 1.6rem; letter-spacing: 0.01em; margin: 0 0 0.5rem;
  }
  .n-svp-{{ section.id }} .n-svp__cell p { font-size: 1.42rem; line-height: 1.55; color: #6a6a6e; margin: 0; }

  /* booking strip */
  .n-svp-{{ section.id }} .n-svp__strip {
    margin-top: clamp(4rem, 7vw, 6rem); background: #101114; border-radius: 18px;
    padding: clamp(2.4rem, 4vw, 3.4rem) clamp(2rem, 4vw, 3.4rem);
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.6rem 2.4rem;
  }
  .n-svp-{{ section.id }} .n-svp__strip-t {
    font-family: var(--font-heading-family); color: #fff; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.01em; font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1.1; margin: 0;
  }
  .n-svp-{{ section.id }} .n-svp__strip-s { color: rgba(255,255,255,0.66); font-size: 1.5rem; margin: 0.6rem 0 0; }
  .n-svp-{{ section.id }} .n-svp__strip-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .n-svp-{{ section.id }} .n-svp__btn {
    display: inline-flex; align-items: center; justify-content: center; padding: 1rem 1.9rem; font-weight: 700;
    font-size: 1.52rem; letter-spacing: 0.02em; text-decoration: none; border-radius: 3px;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .n-svp-{{ section.id }} .n-svp__btn--primary { background: #e11b22; color: #fff; }
  .n-svp-{{ section.id }} .n-svp__btn--primary:hover { background: #c3141b; transform: translateY(-2px); }
  .n-svp-{{ section.id }} .n-svp__btn--ghost { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.4); }
  .n-svp-{{ section.id }} .n-svp__btn--ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); transform: translateY(-2px); }

  @media (max-width: 900px) {
    .n-svp-{{ section.id }} .n-svp__wrap { padding: 0 2rem; }
    .n-svp-{{ section.id }} .n-svp__intro { grid-template-columns: 1fr; align-items: start; gap: 1.2rem; }
    .n-svp-{{ section.id }} .n-svp__row { grid-template-columns: 1fr; gap: 1.8rem; }
    .n-svp-{{ section.id }} .n-svp__row--flip .n-svp__media { order: 0; }
    .n-svp-{{ section.id }} .n-svp__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .n-svp-{{ section.id }} .n-svp__grid { grid-template-columns: 1fr; }
    .n-svp-{{ section.id }} .n-svp__strip { flex-direction: column; align-items: flex-start; }
  }
{%- endstyle -%}

<div class="n-svp-{{ section.id }}">
  <div class="n-svp__wrap">

    <div class="n-svp__intro">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="n-svp__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2 class="n-svp__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.lead != blank -%}<p class="n-svp__lead">{{ section.settings.lead | escape }}</p>{%- endif -%}
    </div>

    <div class="n-svp__rows">
      {%- assign arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>' -%}
      {%- assign tick = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' -%}
      {%- for block in section.blocks -%}
        {%- assign flip = '' -%}
        {%- assign mod = forloop.index | modulo: 2 -%}
        {%- if mod == 0 -%}{%- assign flip = ' n-svp__row--flip' -%}{%- endif -%}
        <div class="n-svp__row{{ flip }}" {{ block.shopify_attributes }}>
          <div class="n-svp__media">
            <div class="n-svp__media-img">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(max-width: 900px) 90vw, 45vw', widths: '500, 750, 1000, 1200' }}
              {%- else -%}
                <img src="{{ block.settings.fallback_image | default: 'niche-services-feature.jpg' | asset_url }}" alt="{{ block.settings.title | escape }} at Niche Automotive" loading="lazy" width="1000" height="750">
              {%- endif -%}
            </div>
          </div>
          <div class="n-svp__body">
            {%- assign n = forloop.index | prepend: '0' -%}
            <span class="n-svp__num">/ {{ n }}</span>
            {%- if block.settings.title != blank -%}<h3 class="n-svp__h">{{ block.settings.title | escape }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<p class="n-svp__p">{{ block.settings.text | escape }}</p>{%- endif -%}
            {%- assign feats = block.settings.features | split: '|' -%}
            {%- if feats.size > 0 and block.settings.features != blank -%}
              <ul class="n-svp__list">
                {%- for f in feats -%}<li>{{ tick }}<span>{{ f | strip | escape }}</span></li>{%- endfor -%}
              </ul>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <a class="n-svp__cta" href="{{ block.settings.cta_link | default: '/pages/contact' }}">{{ block.settings.cta_label | escape }}{{ arrow }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_more -%}
    <div class="n-svp__more">
      <div class="n-svp__more-head">
        {%- if section.settings.more_eyebrow != blank -%}<span class="n-svp__eyebrow" style="justify-content:center">{{ section.settings.more_eyebrow | escape }}</span>{%- endif -%}
        {%- if section.settings.more_title != blank -%}<h2>{{ section.settings.more_title | escape }}</h2>{%- endif -%}
      </div>
      <div class="n-svp__grid">
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>
          <h3>Mechanical Repairs</h3>
          <p>Diagnosis and repairs across all makes and models, done right the first time.</p>
        </div>
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15.5 9.5"/></svg></span>
          <h3>Log Book Servicing</h3>
          <p>Manufacturer-schedule servicing that keeps your new car warranty intact.</p>
        </div>
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
          <h3>Pre-Purchase Inspections</h3>
          <p>Know exactly what you are buying before you commit, with a full report.</p>
        </div>
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/></svg></span>
          <h3>Diagnostic Scans</h3>
          <p>Pinpoint faults fast with proper diagnostic equipment, no guesswork.</p>
        </div>
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          <h3>Brakes &amp; Suspension</h3>
          <p>Brake, suspension, battery and cooling system work to keep you safe.</p>
        </div>
        <div class="n-svp__cell">
          <span class="n-svp__cell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="3" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="21"/><line x1="3" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="21" y2="12"/></svg></span>
          <h3>Wheels &amp; Tyres</h3>
          <p>Fitting, balancing and replacement to suit your car and your driving.</p>
        </div>
      </div>
    </div>
    {%- endif -%}

    {%- if section.settings.show_strip -%}
    <div class="n-svp__strip">
      <div>
        {%- if section.settings.strip_title != blank -%}<p class="n-svp__strip-t">{{ section.settings.strip_title | escape }}</p>{%- endif -%}
        {%- if section.settings.strip_sub != blank -%}<p class="n-svp__strip-s">{{ section.settings.strip_sub | escape }}</p>{%- endif -%}
      </div>
      <div class="n-svp__strip-actions">
        {%- if section.settings.strip_btn_label != blank -%}
          <a class="n-svp__btn n-svp__btn--primary" href="{{ section.settings.strip_btn_link | default: '/pages/contact' }}">{{ section.settings.strip_btn_label | escape }}</a>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <a class="n-svp__btn n-svp__btn--ghost" href="tel:{{ section.settings.phone | remove: ' ' }}">Call {{ section.settings.phone | escape }}</a>
        {%- endif -%}
      </div>
    </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Niche Services Page",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Full-Service Workshop" },
    { "type": "text", "id": "title", "label": "Heading", "default": "What We Do" },
    { "type": "textarea", "id": "lead", "label": "Lead paragraph", "default": "Whatever your car needs, we cover it under one roof. These are the jobs we do most, all backed by honest advice and fair, upfront pricing." },
    { "type": "header", "content": "More services grid" },
    { "type": "checkbox", "id": "show_more", "label": "Show support-services grid", "default": true },
    { "type": "text", "id": "more_eyebrow", "label": "Grid eyebrow", "default": "Also In The Workshop" },
    { "type": "text", "id": "more_title", "label": "Grid heading", "default": "Everything Else Your Car Needs" },
    { "type": "header", "content": "Booking strip" },
    { "type": "checkbox", "id": "show_strip", "label": "Show booking strip", "default": true },
    { "type": "text", "id": "strip_title", "label": "Strip heading", "default": "Not Sure What You Need?" },
    { "type": "text", "id": "strip_sub", "label": "Strip subtext", "default": "Tell us the make, model and what's going on, and we'll point you the right way." },
    { "type": "text", "id": "strip_btn_label", "label": "Strip button label", "default": "Book a Service" },
    { "type": "url", "id": "strip_btn_link", "label": "Strip button link" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "0411 019 935" },
    { "type": "header", "content": "Section" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Padding top", "default": 88 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Padding bottom", "default": 88 }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo", "info": "Leave empty to use the baked fallback below." },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset filename", "default": "niche-services-feature.jpg" },
        { "type": "text", "id": "title", "label": "Service name", "default": "Servicing" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "textarea", "id": "features", "label": "Feature points (separate with | )" },
        { "type": "text", "id": "cta_label", "label": "Link label", "default": "Book This In" },
        { "type": "url", "id": "cta_link", "label": "Link" }
      ]
    }
  ],
  "presets": [ { "name": "Niche Services Page" } ]
}
{% endschema %}
