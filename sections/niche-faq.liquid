{%- comment -%}
  Niche Automotive - FAQ accordion. (build 1)
  Two-column: sticky header (left) + native <details> accordion (right, from blocks).
  No JS required. Self-contained, scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-faq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: #0f0f0f;
  }
  .n-faq-{{ section.id }} .n-faq__wrap {
    max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem;
    display: grid; grid-template-columns: 0.82fr 1.18fr; gap: 3.5rem; align-items: start;
  }
  .n-faq-{{ section.id }} .n-faq__head { position: sticky; top: 96px; }
  .n-faq-{{ section.id }} .n-faq__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem; font-size: 1.2rem; letter-spacing: 0.22em;
    text-transform: uppercase; font-weight: 600; color: #e11b22; margin: 0 0 1rem;
  }
  .n-faq-{{ section.id }} .n-faq__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-faq-{{ section.id }} .n-faq__title {
    font-family: var(--font-heading-family); color: #0f0f0f; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.01em; font-size: clamp(2.2rem, 3.8vw, 3.2rem); line-height: 1.03; margin: 0 0 1.1rem;
  }
  .n-faq-{{ section.id }} .n-faq__intro { font-size: 1.55rem; line-height: 1.6; color: #4a4a4e; margin: 0 0 1.6rem; max-width: 34ch; }
  .n-faq-{{ section.id }} .n-faq__cta { font-size: 1.5rem; color: #0f0f0f; }
  .n-faq-{{ section.id }} .n-faq__cta a { color: #e11b22; font-weight: 700; text-decoration: none; }
  .n-faq-{{ section.id }} .n-faq__cta a:hover { text-decoration: underline; }

  .n-faq-{{ section.id }} .n-faq__list { border-top: 1px solid rgba(15,15,15,0.12); }
  .n-faq-{{ section.id }} .n-faq__item { border-bottom: 1px solid rgba(15,15,15,0.12); }
  .n-faq-{{ section.id }} .n-faq__q {
    list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem;
    padding: 1.5rem 0; font-family: var(--font-heading-family); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.01em; font-size: 1.65rem; line-height: 1.2; color: #0f0f0f;
  }
  .n-faq-{{ section.id }} .n-faq__q::-webkit-details-marker { display: none; }
  .n-faq-{{ section.id }} .n-faq__ico {
    flex: 0 0 auto; width: 30px; height: 30px; border-radius: 50%; display: grid; place-items: center;
    background: rgba(225,27,34,0.10); color: #e11b22; transition: background 0.18s ease, color 0.18s ease, transform 0.25s ease;
  }
  .n-faq-{{ section.id }} .n-faq__ico svg { width: 15px; height: 15px; }
  .n-faq-{{ section.id }} details[open] .n-faq__ico { background: #e11b22; color: #fff; transform: rotate(180deg); }
  .n-faq-{{ section.id }} .n-faq__a { padding: 0 3rem 1.6rem 0; margin: 0; font-size: 1.5rem; line-height: 1.65; color: #4a4a4e; }

  @media (max-width: 860px) {
    .n-faq-{{ section.id }} .n-faq__wrap { grid-template-columns: 1fr; gap: 2rem; padding: 0 2rem; }
    .n-faq-{{ section.id }} .n-faq__head { position: static; }
  }
{%- endstyle -%}

<div class="n-faq-{{ section.id }}">
  <div class="n-faq__wrap">
    <div class="n-faq__head">
      {%- if section.settings.eyebrow != blank -%}<span class="n-faq__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
      {%- if section.settings.title != blank -%}<h2 class="n-faq__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      {%- if section.settings.intro != blank -%}<p class="n-faq__intro">{{ section.settings.intro | escape }}</p>{%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <p class="n-faq__cta">{{ section.settings.cta_text | escape }} <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a></p>
      {%- endif -%}
    </div>

    <div class="n-faq__list">
      {%- for block in section.blocks -%}
        <details class="n-faq__item" {{ block.shopify_attributes }}>
          <summary class="n-faq__q">
            <span>{{ block.settings.question | escape }}</span>
            <span class="n-faq__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
          </summary>
          {%- if block.settings.answer != blank -%}<p class="n-faq__a">{{ block.settings.answer | escape | newline_to_br }}</p>{%- endif -%}
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Niche FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Everything you need to know before you book your car in or shop the parts store." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Still have a question? Call us on" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "0411 019 935" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 84 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Your answer here." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Niche FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "What areas do you service?", "answer": "We're based in Sunshine West and look after customers right across Melbourne's western suburbs." } },
        { "type": "faq", "settings": { "question": "Do you work on all makes and models?", "answer": "Yes. From daily drivers to weekend projects, we service and repair all makes and models." } },
        { "type": "faq", "settings": { "question": "Will a service affect my new car warranty?", "answer": "No. Our log book servicing follows the manufacturer's schedule, so your new car warranty stays intact." } },
        { "type": "faq", "settings": { "question": "Do you sell second-hand parts?", "answer": "Yes. We stock a growing range of quality second-hand parts and can help track down hard-to-find items." } },
        { "type": "faq", "settings": { "question": "Do you give upfront pricing?", "answer": "Always. We provide clear, upfront quotes before any work starts, so there are no surprises." } },
        { "type": "faq", "settings": { "question": "How do I book my car in?", "answer": "Give us a call on 0411 019 935 or send an enquiry through the contact form and we'll get you sorted." } }
      ]
    }
  ]
}
{% endschema %}
