{%- comment -%}
  Niche Automotive - Reusable sub-page header. (build 2 - rotating background)
  Compact dark banner for interior pages. Eyebrow + big uppercase title (optional red
  accent word) + lead line. Background can ROTATE through a set of baked asset photos
  (cross-fade), or show a single image. Priority: image_picker > rotating set > single
  fallback asset. Rotation is CSS/JS cross-fade, respects reduced-motion. Scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-ph-{{ section.id }} {
    position: relative; overflow: hidden; background: #0d0d0f; color: #fff;
  }
  .n-ph-{{ section.id }}__bg { position: absolute; inset: 0; z-index: 0; }
  .n-ph-{{ section.id }}__slide {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; object-position: 50% {{ section.settings.focal_y | default: 80 }}%; display: block;
    filter: brightness(0.4) saturate(0.8) contrast(1.06);
    opacity: 0; transition: opacity 1.4s ease;
  }
  .n-ph-{{ section.id }}__slide.is-active { opacity: 1; }
  .n-ph-{{ section.id }}__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(180deg, rgba(9,9,11,0.55) 0%, rgba(9,9,11,0.72) 55%, rgba(9,9,11,0.96) 100%);
  }
  .n-ph-{{ section.id }}__inner {
    position: relative; z-index: 2; max-width: {{ settings.page_width }}px; margin: 0 auto;
    padding: clamp(5rem, 9vw, 7rem) 2.5rem clamp(5rem, 9vw, 7rem);
    text-align: center;
    min-height: {{ section.settings.min_height | default: 62 }}vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .n-ph-{{ section.id }}__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.2rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600;
    color: #ff5a60; margin: 0 0 1.2rem;
  }
  .n-ph-{{ section.id }}__eyebrow::before,
  .n-ph-{{ section.id }}__eyebrow::after { content: ""; width: 26px; height: 2px; background: #e11b22; }
  .n-ph-{{ section.id }}__title {
    font-family: var(--font-heading-family); color: #fff; font-weight: 700; text-transform: uppercase;
    line-height: 0.94; letter-spacing: 0.005em; font-size: clamp(3rem, 6.6vw, 6rem); margin: 0 auto;
    max-width: 18ch; text-shadow: 0 4px 30px rgba(0,0,0,0.45);
  }
  .n-ph-{{ section.id }}__title .accent { color: #e11b22; }
  .n-ph-{{ section.id }}__sub {
    margin: 1.6rem auto 0; max-width: 62ch; font-size: clamp(1.45rem, 1.6vw, 1.65rem);
    line-height: 1.6; color: rgba(255,255,255,0.78);
  }
  @media (max-width: 749px) {
    .n-ph-{{ section.id }}__inner { padding-left: 2rem; padding-right: 2rem; }
  }
{%- endstyle -%}

{%- liquid
  assign rotate_ms = section.settings.rotate_seconds | default: 5 | times: 1000
  assign slide_class = 'n-ph-' | append: section.id | append: '__slide is-active'
-%}

<div class="n-ph-{{ section.id }}">
  <div class="n-ph-{{ section.id }}__bg" data-rotate-ms="{{ rotate_ms }}">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2200 | image_tag: class: slide_class, loading: 'eager', sizes: '100vw', widths: '750, 1100, 1500, 1900, 2200' }}
    {%- else -%}
      {%- assign ri_list = section.settings.rotate_images | split: ',' -%}
      {%- assign shown = 0 -%}
      {%- for raw in ri_list -%}
        {%- assign fn = raw | strip -%}
        {%- if fn != blank -%}
          <img class="n-ph-{{ section.id }}__slide{% if shown == 0 %} is-active{% endif %}" src="{{ fn | asset_url }}" alt="Niche Automotive workshop in Sunshine West" {% if shown == 0 %}loading="eager"{% else %}loading="lazy"{% endif %} width="1600" height="900">
          {%- assign shown = shown | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if shown == 0 -%}
        <img class="n-ph-{{ section.id }}__slide is-active" src="{{ section.settings.fallback_image | default: 'niche-services-feature.jpg' | asset_url }}" alt="Niche Automotive workshop in Sunshine West" loading="eager" width="1600" height="900">
      {%- endif -%}
    {%- endif -%}
  </div>
  <div class="n-ph-{{ section.id }}__scrim"></div>
  <div class="n-ph-{{ section.id }}__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="n-ph-{{ section.id }}__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    <h1 class="n-ph-{{ section.id }}__title">
      {{ section.settings.heading | escape }}
      {%- if section.settings.heading_accent != blank %} <span class="accent">{{ section.settings.heading_accent | escape }}</span>{%- endif -%}
    </h1>
    {%- if section.settings.subtext != blank -%}
      <p class="n-ph-{{ section.id }}__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var bg = document.querySelector('.n-ph-{{ section.id }}__bg');
    if (!bg || bg.dataset.rInit) return;
    bg.dataset.rInit = '1';
    var slides = bg.querySelectorAll('.n-ph-{{ section.id }}__slide');
    if (slides.length < 2) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var ms = parseInt(bg.dataset.rotateMs, 10) || 5000;
    var i = 0;
    setInterval(function () {
      slides[i].classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
    }, ms);
  })();
</script>

{% schema %}
{
  "name": "Niche Page Header",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Background priority: a single uploaded image (below) overrides everything; otherwise the rotating photo set rotates; otherwise the single fallback asset shows." },
    { "type": "image_picker", "id": "image", "label": "Single background image (optional)", "info": "Set this to pin ONE static image and turn off rotation for this page." },
    { "type": "textarea", "id": "rotate_images", "label": "Rotating background photos", "default": "niche-gallery-front-1.jpg, niche-gallery-front-2.jpg, niche-gallery-front-3.jpg, niche-gallery-front-4.jpg, niche-workshop-front.jpg, niche-shopfront.jpg", "info": "Comma-separated asset filenames. 2+ photos cross-fade in the background. Clear this to use the single fallback below." },
    { "type": "range", "id": "rotate_seconds", "min": 3, "max": 10, "step": 1, "unit": "s", "label": "Seconds per photo", "default": 5 },
    { "type": "range", "id": "min_height", "min": 30, "max": 90, "step": 2, "unit": "vh", "label": "Banner height", "default": 62 },
    { "type": "range", "id": "focal_y", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Photo focal point (0 = top, 100 = bottom)", "default": 80 },
    { "type": "text", "id": "fallback_image", "label": "Fallback asset filename", "default": "niche-services-feature.jpg", "info": "Used only if no image is uploaded and the rotating set is empty." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What We Do" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Workshop" },
    { "type": "text", "id": "heading_accent", "label": "Heading (red highlight)", "default": "Services" },
    { "type": "textarea", "id": "subtext", "label": "Lead line", "default": "From routine servicing to full engine builds and restorations, we look after all makes and models with honest advice and quality workmanship." }
  ],
  "presets": [ { "name": "Niche Page Header" } ]
}
{% endschema %}
