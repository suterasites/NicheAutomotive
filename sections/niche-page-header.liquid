{%- comment -%}
  Niche Automotive - Reusable sub-page header. (build 1)
  Compact dark banner for interior pages (Services, About, Contact). Eyebrow +
  big uppercase title (optional red accent word) + lead line. Optional background
  photo with a dark brand scrim; falls back to a baked workshop asset.
  Self-contained: all CSS scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-ph-{{ section.id }} {
    position: relative; overflow: hidden; background: #0d0d0f; color: #fff;
  }
  .n-ph-{{ section.id }}__bg { position: absolute; inset: 0; z-index: 0; }
  .n-ph-{{ section.id }}__bg img {
    width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;
    filter: brightness(0.4) saturate(0.8) contrast(1.06);
  }
  .n-ph-{{ section.id }}__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(180deg, rgba(9,9,11,0.55) 0%, rgba(9,9,11,0.72) 55%, rgba(9,9,11,0.96) 100%);
  }
  .n-ph-{{ section.id }}__inner {
    position: relative; z-index: 2; max-width: {{ settings.page_width }}px; margin: 0 auto;
    padding: clamp(5.5rem, 10vw, 8rem) 2.5rem clamp(4.5rem, 8vw, 6rem);
    text-align: center;
  }
  .n-ph-{{ section.id }}__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.2rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600;
    color: #ff5a60; margin: 0 0 1.2rem;
  }
  .n-ph-{{ section.id }}__eyebrow::before,
  .n-ph-{{ section.id }}__eyebrow::after { content: ""; width: 26px; height: 2px; background: #e11b22; }
  .n-ph-{{ section.id }}__title {
    font-family: var(--font-heading-family); color: #fff; font-weight: 700; text-transform: uppercase;
    line-height: 0.94; letter-spacing: 0.005em; font-size: clamp(3rem, 6.6vw, 6rem); margin: 0 auto;
    max-width: 18ch; text-shadow: 0 4px 30px rgba(0,0,0,0.45);
  }
  .n-ph-{{ section.id }}__title .accent { color: #e11b22; }
  .n-ph-{{ section.id }}__sub {
    margin: 1.6rem auto 0; max-width: 62ch; font-size: clamp(1.45rem, 1.6vw, 1.65rem);
    line-height: 1.6; color: rgba(255,255,255,0.78);
  }
  @media (max-width: 749px) {
    .n-ph-{{ section.id }}__inner { padding-left: 2rem; padding-right: 2rem; }
  }
{%- endstyle -%}

<div class="n-ph-{{ section.id }}">
  <div class="n-ph-{{ section.id }}__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2200 | image_tag: loading: 'eager', sizes: '100vw', widths: '750, 1100, 1500, 1900, 2200' }}
    {%- else -%}
      <img src="{{ section.settings.fallback_image | default: 'niche-services-feature.jpg' | asset_url }}" alt="Niche Automotive workshop in Sunshine West" loading="eager" width="1600" height="900">
    {%- endif -%}
  </div>
  <div class="n-ph-{{ section.id }}__scrim"></div>
  <div class="n-ph-{{ section.id }}__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="n-ph-{{ section.id }}__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    <h1 class="n-ph-{{ section.id }}__title">
      {{ section.settings.heading | escape }}
      {%- if section.settings.heading_accent != blank %} <span class="accent">{{ section.settings.heading_accent | escape }}</span>{%- endif -%}
    </h1>
    {%- if section.settings.subtext != blank -%}
      <p class="n-ph-{{ section.id }}__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Niche Page Header",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (optional)", "info": "Leave empty to use the baked workshop photo below." },
    { "type": "text", "id": "fallback_image", "label": "Fallback asset filename", "default": "niche-services-feature.jpg" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What We Do" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Workshop" },
    { "type": "text", "id": "heading_accent", "label": "Heading (red highlight)", "default": "Services" },
    { "type": "textarea", "id": "subtext", "label": "Lead line", "default": "From routine servicing to full engine builds and restorations, we look after all makes and models with honest advice and quality workmanship." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (unused)", "default": 0 }
  ],
  "presets": [ { "name": "Niche Page Header" } ]
}
{% endschema %}
