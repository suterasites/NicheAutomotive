{%- comment -%}
  Niche Automotive - custom branded footer. (build 1)
  Self-contained: dark premium footer with optional call-to-action band, brand column,
  link columns (mirrors the planned site structure), contact/hours, and a bottom bar.
  All CSS scoped by section.id. Logo falls back to the asset if none picked in the editor.
{%- endcomment -%}

{%- style -%}
  .n-ft-{{ section.id }} {
    background: #0c0c0e;
    color: rgba(255,255,255,0.72);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .n-ft-{{ section.id }} .n-ft__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }

  /* CTA band */
  .n-ft-{{ section.id }} .n-ft__cta {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.6rem;
    background: linear-gradient(120deg, #e11b22 0%, #a5121a 100%);
    border-radius: 16px; padding: 2.2rem 2.6rem; margin-bottom: 3.5rem;
  }
  .n-ft-{{ section.id }} .n-ft__cta-txt h3 {
    font-family: var(--font-heading-family); color: #fff; text-transform: uppercase; font-weight: 700;
    letter-spacing: 0.01em; font-size: clamp(2.17rem, 2.8vw, 2.9rem); line-height: 1.05; margin: 0 0 0.4rem;
  }
  .n-ft-{{ section.id }} .n-ft__cta-txt p { color: rgba(255,255,255,0.9); margin: 0; font-size: 1.47rem; }
  .n-ft-{{ section.id }} .n-ft__cta-actions { display: flex; align-items: center; gap: 1.4rem; flex-wrap: wrap; }
  .n-ft-{{ section.id }} .n-ft__cta-phone { font-family: var(--font-heading-family); font-weight: 700; color: #fff; text-decoration: none; font-size: 2.17rem; letter-spacing: 0.01em; }
  .n-ft-{{ section.id }} .n-ft__cta-phone:hover { text-decoration: underline; }
  .n-ft-{{ section.id }} .n-ft__cta-btn {
    display: inline-flex; align-items: center; justify-content: center; background: #fff; color: #111;
    font-weight: 700; text-decoration: none; padding: 0.9rem 1.8rem; border-radius: 3px; letter-spacing: 0.02em;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .n-ft-{{ section.id }} .n-ft__cta-btn:hover { transform: translateY(-2px); background: #111; color: #fff; }

  /* columns */
  .n-ft-{{ section.id }} .n-ft__cols {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.4fr; gap: 2.6rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .n-ft-{{ section.id }} .n-ft__logo { display: block; width: 172px; max-width: 60%; height: auto; margin: 0 0 1.2rem; }
  .n-ft-{{ section.id }} .n-ft__tag { font-size: 1.43rem; line-height: 1.6; margin: 0 0 1.5rem; max-width: 34ch; }
  .n-ft-{{ section.id }} .n-ft__social { display: flex; gap: 0.7rem; margin: 0; padding: 0; list-style: none; }
  .n-ft-{{ section.id }} .n-ft__social a {
    display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px;
    border-radius: 9px; background: rgba(255,255,255,0.06); color: #fff; transition: background 0.15s ease, transform 0.15s ease;
  }
  .n-ft-{{ section.id }} .n-ft__social a:hover { background: #e11b22; transform: translateY(-2px); }
  .n-ft-{{ section.id }} .n-ft__social svg { width: 19px; height: 19px; }

  .n-ft-{{ section.id }} .n-ft__h {
    font-family: var(--font-heading-family); color: #fff; text-transform: uppercase; font-weight: 600;
    letter-spacing: 0.14em; font-size: 1.24rem; margin: 0.4rem 0 1.2rem;
  }
  .n-ft-{{ section.id }} .n-ft__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .n-ft-{{ section.id }} .n-ft__list a { color: rgba(255,255,255,0.68); text-decoration: none; font-size: 1.46rem; transition: color 0.15s ease; }
  .n-ft-{{ section.id }} .n-ft__list a:hover { color: #fff; }

  .n-ft-{{ section.id }} .n-ft__contact { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .n-ft-{{ section.id }} .n-ft__contact li { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 1.46rem; line-height: 1.45; }
  .n-ft-{{ section.id }} .n-ft__contact svg { flex: 0 0 auto; width: 18px; height: 18px; margin-top: 2px; color: #e11b22; }
  .n-ft-{{ section.id }} .n-ft__contact a { color: rgba(255,255,255,0.72); text-decoration: none; }
  .n-ft-{{ section.id }} .n-ft__contact a:hover { color: #fff; }
  .n-ft-{{ section.id }} .n-ft__hours { display: flex; flex-direction: column; gap: 0.35rem; }
  .n-ft-{{ section.id }} .n-ft__hours span { display: flex; justify-content: space-between; gap: 1.2rem; }
  .n-ft-{{ section.id }} .n-ft__hours b { color: #fff; font-weight: 600; }

  /* bottom bar */
  .n-ft-{{ section.id }} .n-ft__bar {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.8rem;
    padding-top: 1.8rem; font-size: 1.27rem; color: rgba(255,255,255,0.5);
  }
  .n-ft-{{ section.id }} .n-ft__bar a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .n-ft-{{ section.id }} .n-ft__bar a:hover { color: #fff; text-decoration: underline; }

  @media (max-width: 990px) {
    .n-ft-{{ section.id }} .n-ft__cols { grid-template-columns: 1fr 1fr; gap: 2.2rem 2rem; }
    .n-ft-{{ section.id }} .n-ft__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .n-ft-{{ section.id }} .n-ft__wrap { padding: 0 2rem; }
    .n-ft-{{ section.id }} .n-ft__cols { grid-template-columns: 1fr; }
    .n-ft-{{ section.id }} .n-ft__cta { padding: 1.8rem; }
  }
{%- endstyle -%}

<div class="n-ft-{{ section.id }}">
  <div class="n-ft__wrap">

    {%- if section.settings.show_cta -%}
      <div class="n-ft__cta">
        <div class="n-ft__cta-txt">
          <h3>{{ section.settings.cta_heading | escape }}</h3>
          {%- if section.settings.cta_text != blank -%}<p>{{ section.settings.cta_text | escape }}</p>{%- endif -%}
        </div>
        <div class="n-ft__cta-actions">
          {%- if section.settings.phone != blank -%}
            <a class="n-ft__cta-phone" href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a>
          {%- endif -%}
          {%- if section.settings.cta_button_label != blank -%}
            <a class="n-ft__cta-btn" href="{{ section.settings.cta_button_link | default: '/pages/contact' }}">{{ section.settings.cta_button_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="n-ft__cols">

      {%- comment -%} Brand {%- endcomment -%}
      <div class="n-ft__brand">
        {%- if section.settings.logo != blank -%}
          <img class="n-ft__logo" src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name | escape }}" width="172" height="auto" loading="lazy">
        {%- else -%}
          <img class="n-ft__logo" src="{{ 'niche-logo-white.png' | asset_url }}" alt="{{ shop.name | escape }}" width="172" loading="lazy">
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}<p class="n-ft__tag">{{ section.settings.tagline | escape }}</p>{%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <ul class="n-ft__social">
            <li>
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            </li>
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Explore {%- endcomment -%}
      <div>
        <p class="n-ft__h">Explore</p>
        <ul class="n-ft__list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="/collections/all">Shop Parts</a></li>
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

      {%- comment -%} Services {%- endcomment -%}
      <div>
        <p class="n-ft__h">Services</p>
        <ul class="n-ft__list">
          <li><a href="/pages/servicing">Servicing</a></li>
          <li><a href="/pages/performance-upgrades">Performance Upgrades</a></li>
          <li><a href="/pages/engine-builds">Engine Builds &amp; Rebuilds</a></li>
          <li><a href="/pages/engine-conversions">Engine Conversions</a></li>
          <li><a href="/pages/restoration">Restoration</a></li>
        </ul>
      </div>

      {%- comment -%} Contact / Visit {%- endcomment -%}
      <div>
        <p class="n-ft__h">Visit Us</p>
        <ul class="n-ft__contact">
          {%- if section.settings.address != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{{ section.settings.address | escape }}</span>
            </li>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.68 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.32 1.85.55 2.81.68A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6L2 7"/></svg>
              <a href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email | escape }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.hours != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>
              <span class="n-ft__hours">
                {%- assign rows = section.settings.hours | split: '|' -%}
                {%- for row in rows -%}
                  {%- assign parts = row | split: '~' -%}
                  {%- if parts.size > 1 -%}
                    <span><b>{{ parts[0] | strip | escape }}</b>{{ parts[1] | strip | escape }}</span>
                  {%- else -%}
                    <span>{{ row | strip | escape }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </span>
            </li>
          {%- endif -%}
        </ul>
      </div>

    </div>

    <div class="n-ft__bar">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}{% if section.settings.abn != blank %} &nbsp;&middot;&nbsp; ABN {{ section.settings.abn | escape }}{% endif %}. All rights reserved.</span>
      {%- if section.settings.show_credit -%}
        <span>Website by <a href="https://suterasites.com" target="_blank" rel="noopener">Sutera Sites</a></span>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Niche Footer",
  "settings": [
    { "type": "header", "content": "Call-to-action band" },
    { "type": "checkbox", "id": "show_cta", "label": "Show call-to-action band", "default": true },
    { "type": "text", "id": "cta_heading", "label": "CTA heading", "default": "Ready to Book Your Car In?" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Call the workshop or send an enquiry and we'll get you sorted." },
    { "type": "text", "id": "cta_button_label", "label": "CTA button label", "default": "Send an Enquiry" },
    { "type": "url", "id": "cta_button_link", "label": "CTA button link" },
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Footer logo", "info": "Leave empty to use the built-in white logo." },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Sunshine West's trusted workshop for honest servicing, repairs and quality second-hand parts across all makes and models." },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "address", "label": "Address", "default": "4/94 Boundary Road, Sunshine West VIC 3020" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "0411 019 935" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@nicheautomotive.com.au" },
    { "type": "textarea", "id": "hours", "label": "Opening hours", "info": "One row per line-item separated by | . Use ~ to split day and time. e.g. Mon - Fri ~ 8:00am - 5:00pm", "default": "Mon - Fri ~ 8:00am - 5:00pm | Sat ~ 8:00am - 12:00pm | Sun ~ Closed" },
    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "abn", "label": "ABN", "info": "Leave empty to hide." },
    { "type": "checkbox", "id": "show_credit", "label": "Show 'Website by Sutera Sites' credit", "default": true },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 72 },
    { "type": "range", "id": "padding_bottom", "min": 24, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "presets": [ { "name": "Niche Footer" } ]
}
{% endschema %}
