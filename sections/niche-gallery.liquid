{%- comment -%}
  Niche Automotive - Gallery (mixed image + video masonry).
  CSS-columns masonry; each block is an image or a video tile. Video tiles show a
  poster + play badge only (the <video> itself loads on click in a lightbox), so the
  grid stays light. Lightbox handles both media types with prev/next + keyboard nav.
  Image source: block image_picker (upload) OR baked asset filename. All CSS/JS scoped
  by section.id.
{%- endcomment -%}

{%- style -%}
  .n-gal-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .n-gal-{{ section.id }} .n-gal__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }

  .n-gal-{{ section.id }} .n-gal__head { max-width: 62ch; margin: 0 0 2.6rem; }
  .n-gal-{{ section.id }} .n-gal__kicker {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.3rem; font-weight: 600; letter-spacing: 0.02em; margin: 0 0 1rem; color: {{ section.settings.text_color }};
  }
  .n-gal-{{ section.id }} .n-gal__kicker::before { content: ""; width: 26px; height: 2px; background: #e11b22; display: inline-block; }
  .n-gal-{{ section.id }} .n-gal__title {
    font-family: var(--font-heading-family); font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.005em; line-height: 0.98; margin: 0;
    font-size: clamp(3rem, 5.4vw, 5rem);
  }
  .n-gal-{{ section.id }} .n-gal__lead { margin: 1.2rem 0 0; font-size: 1.55rem; line-height: 1.6; opacity: 0.72; }

  /* masonry */
  .n-gal-{{ section.id }} .n-gal__grid { column-count: 3; column-gap: 1.1rem; }
  .n-gal-{{ section.id }} .n-gal__item {
    position: relative; display: block; width: 100%; margin: 0 0 1.1rem; padding: 0; border: 0;
    background: #131316; border-radius: 13px; overflow: hidden; cursor: pointer;
    break-inside: avoid; -webkit-column-break-inside: avoid;
    box-shadow: 0 6px 18px rgba(10,10,12,0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .n-gal-{{ section.id }} .n-gal__item:hover { transform: translateY(-4px); box-shadow: 0 18px 38px rgba(10,10,12,0.26); }
  .n-gal-{{ section.id }} .n-gal__item:focus-visible { outline: 3px solid #e11b22; outline-offset: 3px; }
  .n-gal-{{ section.id }} .n-gal__media { width: 100%; height: auto; display: block; transition: transform 0.55s ease; }
  .n-gal-{{ section.id }} .n-gal__item:hover .n-gal__media { transform: scale(1.05); }
  .n-gal-{{ section.id }} .n-gal__item::after {
    content: ""; position: absolute; inset: 0; opacity: 0; transition: opacity 0.2s ease;
    background: linear-gradient(180deg, rgba(10,10,12,0) 55%, rgba(10,10,12,0.55) 100%);
  }
  .n-gal-{{ section.id }} .n-gal__item:hover::after { opacity: 1; }

  .n-gal-{{ section.id }} .n-gal__play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 58px; height: 58px; border-radius: 50%; display: grid; place-items: center; z-index: 2;
    background: rgba(225,27,34,0.92); color: #fff; box-shadow: 0 6px 20px rgba(0,0,0,0.35);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .n-gal-{{ section.id }} .n-gal__item:hover .n-gal__play { transform: translate(-50%,-50%) scale(1.08); background: #e11b22; }
  .n-gal-{{ section.id }} .n-gal__play svg { width: 22px; height: 22px; margin-left: 3px; fill: #fff; }
  .n-gal-{{ section.id }} .n-gal__tag {
    position: absolute; top: 0.85rem; left: 0.85rem; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(10,10,12,0.72); color: #fff; font-size: 1.05rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; padding: 0.4rem 0.7rem; border-radius: 999px;
  }
  .n-gal-{{ section.id }} .n-gal__tag::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: #e11b22; }
  .n-gal-{{ section.id }} .n-gal__cap {
    position: absolute; left: 1rem; right: 1rem; bottom: 0.9rem; z-index: 3; color: #fff;
    font-size: 1.28rem; font-weight: 600; line-height: 1.25; opacity: 0; transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease; text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }
  .n-gal-{{ section.id }} .n-gal__item:hover .n-gal__cap { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .n-gal-{{ section.id }} .n-gal__wrap { padding: 0 2rem; }
    .n-gal-{{ section.id }} .n-gal__grid { column-count: 2; column-gap: 0.9rem; }
    .n-gal-{{ section.id }} .n-gal__item { margin-bottom: 0.9rem; }
    .n-gal-{{ section.id }} .n-gal__cap { opacity: 1; transform: none; }
  }
  @media (max-width: 480px) {
    .n-gal-{{ section.id }} .n-gal__play { width: 46px; height: 46px; }
    .n-gal-{{ section.id }} .n-gal__play svg { width: 18px; height: 18px; }
  }

  /* lightbox */
  .n-gal-lb-{{ section.id }} {
    position: fixed; inset: 0; z-index: 99999; display: none;
    align-items: center; justify-content: center;
    background: rgba(8,8,10,0.95); backdrop-filter: blur(3px);
  }
  .n-gal-lb-{{ section.id }}.is-open { display: flex; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__stage {
    position: relative; max-width: 92vw; max-height: 88vh; display: flex; flex-direction: column; align-items: center;
  }
  .n-gal-lb-{{ section.id }} .n-gal-lb__stage img,
  .n-gal-lb-{{ section.id }} .n-gal-lb__stage video {
    max-width: 92vw; max-height: 82vh; width: auto; height: auto; display: block;
    border-radius: 8px; background: #000; box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .n-gal-lb-{{ section.id }} .n-gal-lb__cap {
    color: rgba(255,255,255,0.82); font-size: 1.4rem; margin-top: 1.1rem; text-align: center; max-width: 70ch;
  }
  .n-gal-lb-{{ section.id }} .n-gal-lb__btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 52px; height: 52px; border-radius: 50%; border: 0; cursor: pointer; z-index: 2;
    background: rgba(255,255,255,0.12); color: #fff; display: grid; place-items: center;
    transition: background 0.15s ease;
  }
  .n-gal-lb-{{ section.id }} .n-gal-lb__btn:hover { background: #e11b22; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__btn svg { width: 22px; height: 22px; fill: none; stroke: #fff; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__prev { left: -76px; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__next { right: -76px; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__close {
    position: absolute; top: 2rem; right: 2rem; width: 48px; height: 48px; border-radius: 50%; border: 0; cursor: pointer; z-index: 3;
    background: rgba(255,255,255,0.12); color: #fff; display: grid; place-items: center; transition: background 0.15s ease;
  }
  .n-gal-lb-{{ section.id }} .n-gal-lb__close:hover { background: #e11b22; }
  .n-gal-lb-{{ section.id }} .n-gal-lb__close svg { width: 20px; height: 20px; fill: none; stroke: #fff; stroke-width: 2.4; stroke-linecap: round; }
  @media (max-width: 1100px) {
    .n-gal-lb-{{ section.id }} .n-gal-lb__prev { left: 0.6rem; }
    .n-gal-lb-{{ section.id }} .n-gal-lb__next { right: 0.6rem; }
    .n-gal-lb-{{ section.id }} .n-gal-lb__btn { width: 44px; height: 44px; background: rgba(10,10,12,0.55); }
  }
{%- endstyle -%}

{%- liquid
  assign play_svg = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>'
-%}

<div class="n-gal-{{ section.id }}">
  <div class="n-gal__wrap">
    {%- if section.settings.kicker != blank or section.settings.title != blank or section.settings.lead != blank -%}
      <div class="n-gal__head">
        {%- if section.settings.kicker != blank -%}<p class="n-gal__kicker">{{ section.settings.kicker | escape }}</p>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2 class="n-gal__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
        {%- if section.settings.lead != blank -%}<p class="n-gal__lead">{{ section.settings.lead | escape }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="n-gal__grid" id="n-gal-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'image' -%}
            {%- liquid
              if block.settings.image != blank
                assign full = block.settings.image | image_url: width: 1600
                assign thumb = block.settings.image | image_url: width: 800
              else
                assign full = block.settings.asset | asset_url
                assign thumb = full
              endif
            -%}
            {%- if full != blank -%}
              <button type="button" class="n-gal__item" {{ block.shopify_attributes }}
                      data-type="image" data-full="{{ full }}" data-caption="{{ block.settings.caption | escape }}">
                <img class="n-gal__media" src="{{ thumb }}" alt="{{ block.settings.caption | default: 'Niche Automotive' | escape }}" loading="lazy">
              </button>
            {%- endif -%}
          {%- when 'video' -%}
            {%- liquid
              if block.settings.poster_image != blank
                assign poster = block.settings.poster_image | image_url: width: 800
              else
                assign poster = block.settings.poster | asset_url
              endif
              assign vid = block.settings.video | asset_url
            -%}
            {%- if vid != blank -%}
              <button type="button" class="n-gal__item" {{ block.shopify_attributes }}
                      data-type="video" data-video="{{ vid }}" data-poster="{{ poster }}" data-caption="{{ block.settings.caption | escape }}">
                <img class="n-gal__media" src="{{ poster }}" alt="{{ block.settings.caption | default: 'Niche Automotive video' | escape }}" loading="lazy">
                <span class="n-gal__tag">Video</span>
                <span class="n-gal__play">{{ play_svg }}</span>
              </button>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- comment -%} Lightbox {%- endcomment -%}
<div class="n-gal-lb-{{ section.id }}" id="n-gal-lb-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Gallery viewer">
  <button type="button" class="n-gal-lb__close" data-gal-close aria-label="Close">
    <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
  </button>
  <button type="button" class="n-gal-lb__btn n-gal-lb__prev" data-gal-prev aria-label="Previous">
    <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 6 9 12 15 18"/></svg>
  </button>
  <div class="n-gal-lb__stage" data-gal-stage></div>
  <button type="button" class="n-gal-lb__btn n-gal-lb__next" data-gal-next aria-label="Next">
    <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
  </button>
</div>

<script>
  (function () {
    var root = document.getElementById('n-gal-grid-{{ section.id }}');
    var lb = document.getElementById('n-gal-lb-{{ section.id }}');
    if (!root || !lb || root.dataset.galInit) return;
    root.dataset.galInit = '1';

    var stage = lb.querySelector('[data-gal-stage]');
    var items = Array.prototype.slice.call(root.querySelectorAll('.n-gal__item'));
    var index = -1;

    function render() {
      var el = items[index];
      if (!el) return;
      var type = el.getAttribute('data-type');
      var cap = el.getAttribute('data-caption') || '';
      var media;
      if (type === 'video') {
        media = '<video src="' + el.getAttribute('data-video') + '" poster="' + el.getAttribute('data-poster') + '" controls autoplay playsinline preload="auto"></video>';
      } else {
        media = '<img src="' + el.getAttribute('data-full') + '" alt="' + cap.replace(/"/g, '&quot;') + '">';
      }
      if (cap) media += '<div class="n-gal-lb__cap">' + cap + '</div>';
      stage.innerHTML = media;
      var v = stage.querySelector('video');
      if (v) { var p = v.play(); if (p && p.catch) p.catch(function () {}); }
    }
    function open(i) {
      index = i;
      lb.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
      render();
    }
    function close() {
      lb.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      stage.innerHTML = '';
      index = -1;
    }
    function step(dir) {
      if (index < 0) return;
      index = (index + dir + items.length) % items.length;
      render();
    }

    items.forEach(function (el, i) { el.addEventListener('click', function () { open(i); }); });
    lb.querySelector('[data-gal-close]').addEventListener('click', close);
    lb.querySelector('[data-gal-prev]').addEventListener('click', function () { step(-1); });
    lb.querySelector('[data-gal-next]').addEventListener('click', function () { step(1); });
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  })();
</script>

{% schema %}
{
  "name": "Niche Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Our Work" },
    { "type": "text", "id": "title", "label": "Heading", "default": "From the Workshop" },
    { "type": "textarea", "id": "lead", "label": "Lead text", "default": "A look at the cars, builds and jobs that come through Niche Automotive. Tap any photo or video to view it full size." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F6F8" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#0F0F0F" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 88 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo (upload)", "info": "Takes priority. Leave empty to use a baked asset filename below." },
        { "type": "text", "id": "asset", "label": "Or baked asset filename", "info": "e.g. niche-gallery-resto-v8.jpg (a file already in the theme's assets)." },
        { "type": "text", "id": "caption", "label": "Caption (optional)" }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text", "id": "video", "label": "Video asset filename", "info": "An .mp4 in the theme assets, e.g. niche-gallery-v1.mp4. Plays in a lightbox on click." },
        { "type": "image_picker", "id": "poster_image", "label": "Poster (upload)", "info": "Takes priority over the poster filename below." },
        { "type": "text", "id": "poster", "label": "Or poster asset filename", "info": "e.g. niche-gallery-v1-poster.jpg" },
        { "type": "text", "id": "caption", "label": "Caption (optional)" }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [ { "name": "Niche Gallery" } ]
}
{% endschema %}
