{%- comment -%}
  Niche Automotive - Shop by Category (dark). (build 3 - photo tiles)
  Category tiles that link to collections. Each tile background is a real part
  photo: a manual override image if set, else the linked collection's image,
  else that collection's first product photo, else a dark fallback. A scrim
  keeps the title legible over any photo. Self-contained, scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-cat-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: #ffffff;
  }
  .n-cat-{{ section.id }} .n-cat__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }
  .n-cat-{{ section.id }} .n-cat__head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; margin: 0 0 2.4rem;
  }
  .n-cat-{{ section.id }} .n-cat__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.15rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600; color: #ff5a60; margin: 0 0 0.9rem;
  }
  .n-cat-{{ section.id }} .n-cat__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-cat-{{ section.id }} .n-cat__title {
    font-family: var(--font-heading-family);
    color: #ffffff;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.01em;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.05; margin: 0;
  }
  .n-cat-{{ section.id }} .n-cat__all {
    color: #fff; text-decoration: none; font-weight: 600; font-size: 1.47rem; white-space: nowrap;
    border-bottom: 2px solid #e11b22; padding-bottom: 3px;
  }
  .n-cat-{{ section.id }} .n-cat__all:hover { color: #ff5a60; }
  .n-cat-{{ section.id }} .n-cat__grid {
    display: grid; grid-template-columns: repeat({{ section.settings.columns }}, minmax(0,1fr)); gap: 1rem;
  }
  .n-cat-{{ section.id }} .n-cat__tile {
    position: relative; display: flex; flex-direction: column; justify-content: flex-end;
    min-height: 190px; padding: 1.5rem; text-decoration: none; color: #fff;
    background: #17181c; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;
    overflow: hidden; transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .n-cat-{{ section.id }} .n-cat__tile:hover { transform: translateY(-4px); border-color: rgba(225,27,34,0.6); }
  .n-cat-{{ section.id }} .n-cat__bg { position: absolute; inset: 0; z-index: 0; }
  .n-cat-{{ section.id }} .n-cat__bg img {
    width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;
    transition: transform 0.5s ease;
  }
  .n-cat-{{ section.id }} .n-cat__tile:hover .n-cat__bg img { transform: scale(1.06); }
  .n-cat-{{ section.id }} .n-cat__scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to top, rgba(12,12,14,0.94) 0%, rgba(12,12,14,0.6) 42%, rgba(12,12,14,0.42) 100%);
  }
  .n-cat-{{ section.id }} .n-cat__label { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; }
  .n-cat-{{ section.id }} .n-cat__label h3 {
    font-family: var(--font-heading-family);
    color: #ffffff;
    margin: 0; font-size: 1.74rem; text-transform: uppercase; letter-spacing: 0.02em; font-weight: 600;
    text-shadow: 0 2px 12px rgba(0,0,0,0.5);
  }
  .n-cat-{{ section.id }} .n-cat__arrow { color: #e11b22; flex: 0 0 auto; transition: transform 0.18s ease; }
  .n-cat-{{ section.id }} .n-cat__tile:hover .n-cat__arrow { transform: translateX(4px); }
  @media (max-width: 990px) { .n-cat-{{ section.id }} .n-cat__grid { grid-template-columns: repeat(2, minmax(0,1fr)); } .n-cat-{{ section.id }} .n-cat__wrap { padding: 0 2rem; } }
  @media (max-width: 560px) { .n-cat-{{ section.id }} .n-cat__grid { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 0.75rem; } .n-cat-{{ section.id }} .n-cat__tile { min-height: 150px; } }
{%- endstyle -%}

<div class="n-cat-{{ section.id }}">
  <div class="n-cat__wrap">
    <div class="n-cat__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="n-cat__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2 class="n-cat__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.all_label != blank -%}
        <a class="n-cat__all" href="{{ section.settings.all_link | default: '/collections/all' }}">{{ section.settings.all_label | escape }}</a>
      {%- endif -%}
    </div>

    <div class="n-cat__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign bg = block.settings.image
          if bg == blank
            assign lparts = block.settings.link | default: '' | split: '/collections/'
            assign chandle = lparts | last | split: '?' | first | split: '#' | first | split: '/' | first
            assign col = collections[chandle]
            if col != blank
              if col.image != blank
                assign bg = col.image
              elsif col.products.first.featured_image != blank
                assign bg = col.products.first.featured_image
              endif
            endif
          endif
        -%}
        <a class="n-cat__tile" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if bg != blank -%}
            <span class="n-cat__bg">
              {{ bg | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300, 420, 560, 700, 900', sizes: '(max-width: 990px) 45vw, 22vw', alt: block.settings.title }}
            </span>
          {%- endif -%}
          <span class="n-cat__scrim" aria-hidden="true"></span>
          <span class="n-cat__label">
            <h3>{{ block.settings.title | escape }}</h3>
            <span class="n-cat__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Niche Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Second-Hand Parts Store" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Shop Parts by Category" },
    { "type": "text", "id": "all_label", "label": "View-all label", "default": "View all parts" },
    { "type": "url", "id": "all_link", "label": "View-all link" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columns (desktop)", "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#101114" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Category name", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link (collection)" },
        { "type": "image_picker", "id": "image", "label": "Background image (optional)", "info": "Leave empty to auto-use the linked collection's image, or its first product photo." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Niche Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Engine", "link": "/collections/engine" } },
        { "type": "category", "settings": { "title": "Driveline", "link": "/collections/driveline" } },
        { "type": "category", "settings": { "title": "Suspension", "link": "/collections/suspension" } },
        { "type": "category", "settings": { "title": "Brakes", "link": "/collections/brakes" } },
        { "type": "category", "settings": { "title": "Body & Panels", "link": "/collections/body-panels" } },
        { "type": "category", "settings": { "title": "Electrical", "link": "/collections/electrical" } },
        { "type": "category", "settings": { "title": "Lighting", "link": "/collections/lighting" } },
        { "type": "category", "settings": { "title": "Interior", "link": "/collections/interior" } }
      ]
    }
  ]
}
{% endschema %}
