{%- comment -%}
  Niche Automotive - Shop by Category (dark).
  Category tiles that link to collections. Renders great even before collections
  have products. Self-contained, scoped by section.id.
{%- endcomment -%}

{%- style -%}
  .n-cat-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: #ffffff;
  }
  .n-cat-{{ section.id }} .n-cat__wrap { max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem; }
  .n-cat-{{ section.id }} .n-cat__head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; margin: 0 0 2.4rem;
  }
  .n-cat-{{ section.id }} .n-cat__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.74rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600; color: #ff5a60; margin: 0 0 0.9rem;
  }
  .n-cat-{{ section.id }} .n-cat__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-cat-{{ section.id }} .n-cat__title {
    font-family: var(--font-heading-family);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.01em;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.05; margin: 0;
  }
  .n-cat-{{ section.id }} .n-cat__all {
    color: #fff; text-decoration: none; font-weight: 600; font-size: 0.95rem; white-space: nowrap;
    border-bottom: 2px solid #e11b22; padding-bottom: 3px;
  }
  .n-cat-{{ section.id }} .n-cat__all:hover { color: #ff5a60; }
  .n-cat-{{ section.id }} .n-cat__grid {
    display: grid; grid-template-columns: repeat({{ section.settings.columns }}, minmax(0,1fr)); gap: 1rem;
  }
  .n-cat-{{ section.id }} .n-cat__tile {
    position: relative; display: flex; flex-direction: column; justify-content: space-between; gap: 2.2rem;
    min-height: 168px; padding: 1.5rem; text-decoration: none; color: #fff;
    background: #17181c; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;
    overflow: hidden; transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .n-cat-{{ section.id }} .n-cat__tile::after {
    content: ""; position: absolute; right: -30%; top: -60%; width: 150%; height: 150%;
    background: radial-gradient(closest-side, rgba(225,27,34,0.16), rgba(225,27,34,0)); opacity: 0; transition: opacity 0.22s ease;
  }
  .n-cat-{{ section.id }} .n-cat__tile:hover { transform: translateY(-4px); border-color: rgba(225,27,34,0.6); background: #1c1d22; }
  .n-cat-{{ section.id }} .n-cat__tile:hover::after { opacity: 1; }
  .n-cat-{{ section.id }} .n-cat__ico { width: 40px; height: 40px; color: #ff5a60; position: relative; z-index: 1; }
  .n-cat-{{ section.id }} .n-cat__ico svg { width: 40px; height: 40px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .n-cat-{{ section.id }} .n-cat__label { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; }
  .n-cat-{{ section.id }} .n-cat__label h3 {
    font-family: var(--font-heading-family);
    margin: 0; font-size: 1.12rem; text-transform: uppercase; letter-spacing: 0.02em; font-weight: 600;
  }
  .n-cat-{{ section.id }} .n-cat__arrow { color: #e11b22; transition: transform 0.18s ease; }
  .n-cat-{{ section.id }} .n-cat__tile:hover .n-cat__arrow { transform: translateX(4px); }
  @media (max-width: 990px) { .n-cat-{{ section.id }} .n-cat__grid { grid-template-columns: repeat(2, minmax(0,1fr)); } .n-cat-{{ section.id }} .n-cat__wrap { padding: 0 2rem; } }
  @media (max-width: 560px) { .n-cat-{{ section.id }} .n-cat__grid { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 0.75rem; } .n-cat-{{ section.id }} .n-cat__tile { min-height: 140px; } }
{%- endstyle -%}

<div class="n-cat-{{ section.id }}">
  <div class="n-cat__wrap">
    <div class="n-cat__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="n-cat__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}<h2 class="n-cat__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.all_label != blank -%}
        <a class="n-cat__all" href="{{ section.settings.all_link | default: '/collections/all' }}">{{ section.settings.all_label | escape }}</a>
      {%- endif -%}
    </div>

    <div class="n-cat__grid">
      {%- for block in section.blocks -%}
        <a class="n-cat__tile" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="n-cat__ico">
            {%- case block.settings.icon -%}
              {%- when 'engine' -%}<svg viewBox="0 0 24 24"><path d="M4 13v-2h2l1.5-2H10V7h4v2h3l3 3v3h-2v3h-3l-2-2H9l-2 2H4v-4H2v-2z"/></svg>
              {%- when 'suspension' -%}<svg viewBox="0 0 24 24"><line x1="12" y1="3" x2="12" y2="21"/><path d="M7 5h10M7 9h10M7 13h10M7 17h10" transform="rotate(0 12 12)"/><path d="M8 6l8 3M8 10l8 3M8 14l8 3"/></svg>
              {%- when 'brakes' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="3" x2="12" y2="8"/><line x1="12" y1="16" x2="12" y2="21"/><line x1="3" y1="12" x2="8" y2="12"/><line x1="16" y1="12" x2="21" y2="12"/></svg>
              {%- when 'tyre' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3.2"/><line x1="12" y1="3" x2="12" y2="6.3"/><line x1="12" y1="17.7" x2="12" y2="21"/><line x1="3" y1="12" x2="6.3" y2="12"/><line x1="17.7" y1="12" x2="21" y2="12"/></svg>
              {%- when 'body' -%}<svg viewBox="0 0 24 24"><path d="M3 13l2.5-5A3 3 0 0 1 8.2 6h7.6a3 3 0 0 1 2.7 2l2.5 5"/><path d="M2 13h20v4a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1H6v1a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1z"/><circle cx="6.5" cy="16" r="0.6"/><circle cx="17.5" cy="16" r="0.6"/></svg>
              {%- when 'electrical' -%}<svg viewBox="0 0 24 24"><polygon points="13 2 4 14 11 14 10 22 20 9 13 9 13 2"/></svg>
              {%- when 'lighting' -%}<svg viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 21h4"/><path d="M12 3a6 6 0 0 0-4 10.5c.7.7 1 1.3 1 2.5h6c0-1.2.3-1.8 1-2.5A6 6 0 0 0 12 3z"/></svg>
              {%- when 'fluids' -%}<svg viewBox="0 0 24 24"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg>
              {%- else -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M9 12h6M12 9v6"/></svg>
            {%- endcase -%}
          </span>
          <span class="n-cat__label">
            <h3>{{ block.settings.title | escape }}</h3>
            <span class="n-cat__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Niche Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Second-Hand Parts Store" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Shop Parts by Category" },
    { "type": "text", "id": "all_label", "label": "View-all label", "default": "View all parts" },
    { "type": "url", "id": "all_link", "label": "View-all link", "default": "/collections/all" },
    { "type": "range", "id": "columns", "min": 3, "max": 4, "step": 1, "label": "Columns (desktop)", "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#101114" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "engine", "options": [
          { "value": "engine", "label": "Engine" },
          { "value": "suspension", "label": "Suspension" },
          { "value": "brakes", "label": "Brakes" },
          { "value": "tyre", "label": "Wheels & Tyres" },
          { "value": "body", "label": "Body & Panels" },
          { "value": "electrical", "label": "Electrical" },
          { "value": "lighting", "label": "Lighting" },
          { "value": "fluids", "label": "Fluids & Filters" }
        ] },
        { "type": "text", "id": "title", "label": "Category name", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link (collection)", "default": "/collections/all" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Niche Categories",
      "blocks": [
        { "type": "category", "settings": { "icon": "engine", "title": "Engine", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "suspension", "title": "Suspension", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "brakes", "title": "Brakes", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "tyre", "title": "Wheels & Tyres", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "body", "title": "Body & Panels", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "electrical", "title": "Electrical", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "lighting", "title": "Lighting", "link": "/collections/all" } },
        { "type": "category", "settings": { "icon": "fluids", "title": "Fluids & Filters", "link": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
