{%- comment -%}
  Niche Automotive - About / intro (sits directly below the hero). (build 1)
  Two-column: real workshop photo (with red accent + floating badge) on the left,
  brand intro copy, checklist, owner signature and CTA on the right.
  Self-contained, scoped by section.id. All text colours set explicitly.
{%- endcomment -%}

{%- style -%}
  .n-int-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: #3a3a3d;
  }
  .n-int-{{ section.id }} .n-int__wrap {
    max-width: {{ settings.page_width }}px; margin: 0 auto; padding: 0 2.5rem;
    display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 4rem; align-items: center;
  }
  /* media */
  .n-int-{{ section.id }} .n-int__media { position: relative; }
  .n-int-{{ section.id }} .n-int__img {
    position: relative; z-index: 1; border-radius: 18px; overflow: hidden; aspect-ratio: 1 / 1;
    box-shadow: 0 30px 60px rgba(0,0,0,0.16);
  }
  .n-int-{{ section.id }} .n-int__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .n-int-{{ section.id }} .n-int__accent {
    position: absolute; top: -18px; left: -18px; width: 46%; height: 46%; border-radius: 16px; z-index: 0;
    background: linear-gradient(135deg, #e11b22 0%, #a5121a 100%);
  }
  .n-int-{{ section.id }} .n-int__badge {
    position: absolute; left: 20px; bottom: 20px; z-index: 2;
    display: flex; align-items: center; gap: 0.75rem; max-width: 80%;
    background: rgba(12,12,14,0.92); color: #fff; border-radius: 12px; padding: 0.85rem 1.05rem;
    box-shadow: 0 14px 34px rgba(0,0,0,0.28);
  }
  .n-int-{{ section.id }} .n-int__badge svg { flex: 0 0 auto; width: 26px; height: 26px; color: #ff5a60; }
  .n-int-{{ section.id }} .n-int__badge span { font-weight: 600; font-size: 1.4rem; line-height: 1.25; color: #fff; }
  /* body */
  .n-int-{{ section.id }} .n-int__eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 1.15rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600; color: #e11b22; margin: 0 0 1rem;
  }
  .n-int-{{ section.id }} .n-int__eyebrow::before { content: ""; width: 30px; height: 2px; background: #e11b22; }
  .n-int-{{ section.id }} .n-int__title {
    font-family: var(--font-heading-family); color: #0f0f0f;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.01em;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.06; margin: 0 0 1.3rem;
  }
  .n-int-{{ section.id }} .n-int__p { font-size: 1.58rem; line-height: 1.65; color: #4a4a4e; margin: 0 0 1.1rem; max-width: 54ch; }
  .n-int-{{ section.id }} .n-int__list {
    list-style: none; margin: 1.6rem 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem 1.4rem;
  }
  .n-int-{{ section.id }} .n-int__list li { display: flex; align-items: flex-start; gap: 0.6rem; font-weight: 600; font-size: 1.49rem; color: #1c1c1f; }
  .n-int-{{ section.id }} .n-int__list svg { flex: 0 0 auto; width: 19px; height: 19px; margin-top: 1px; color: #e11b22; }
  .n-int-{{ section.id }} .n-int__foot { display: flex; align-items: center; flex-wrap: wrap; gap: 1.4rem 2rem; margin-top: 2rem; }
  .n-int-{{ section.id }} .n-int__sign { display: flex; align-items: center; gap: 0.85rem; }
  .n-int-{{ section.id }} .n-int__sign::before { content: ""; width: 3px; height: 34px; border-radius: 3px; background: #e11b22; }
  .n-int-{{ section.id }} .n-int__sign b { display: block; font-family: var(--font-heading-family); font-weight: 700; color: #0f0f0f; font-size: 1.58rem; letter-spacing: 0.01em; }
  .n-int-{{ section.id }} .n-int__sign span { display: block; font-size: 1.32rem; color: #6a6a6e; }
  .n-int-{{ section.id }} .n-int__btn {
    display: inline-flex; align-items: center; justify-content: center; background: #e11b22; color: #fff;
    font-weight: 700; text-decoration: none; padding: 0.9rem 1.8rem; border-radius: 3px; letter-spacing: 0.02em;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .n-int-{{ section.id }} .n-int__btn:hover { transform: translateY(-2px); background: #c3141b; }
  @media (max-width: 900px) {
    .n-int-{{ section.id }} .n-int__wrap { grid-template-columns: 1fr; gap: 2.6rem; padding: 0 2rem; }
    .n-int-{{ section.id }} .n-int__media { max-width: 460px; }
  }
  @media (max-width: 480px) {
    .n-int-{{ section.id }} .n-int__list { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<div class="n-int-{{ section.id }}">
  <div class="n-int__wrap">

    <div class="n-int__media">
      <span class="n-int__accent" aria-hidden="true"></span>
      <div class="n-int__img">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(max-width: 900px) 90vw, 45vw', widths: '500, 750, 1000, 1200' }}
        {%- else -%}
          <img src="{{ section.settings.fallback_image | default: 'niche-about.jpg' | asset_url }}" alt="Niche Automotive workshop in Sunshine West" loading="lazy" width="1100" height="1320">
        {%- endif -%}
      </div>
      {%- if section.settings.badge_text != blank -%}
        <div class="n-int__badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15.5 9.5"/></svg>
          <span>{{ section.settings.badge_text | escape }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="n-int__body">
      {%- if section.settings.eyebrow != blank -%}<span class="n-int__eyebrow">{{ section.settings.eyebrow | escape }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="n-int__title">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.body1 != blank -%}<p class="n-int__p">{{ section.settings.body1 | escape }}</p>{%- endif -%}
      {%- if section.settings.body2 != blank -%}<p class="n-int__p">{{ section.settings.body2 | escape }}</p>{%- endif -%}

      {%- assign points = section.settings.points | split: '|' -%}
      {%- if section.settings.points != blank -%}
        <ul class="n-int__list">
          {%- for p in points -%}
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><span>{{ p | strip | escape }}</span></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="n-int__foot">
        {%- if section.settings.signature_name != blank -%}
          <div class="n-int__sign">
            <div>
              <b>{{ section.settings.signature_name | escape }}</b>
              {%- if section.settings.signature_role != blank -%}<span>{{ section.settings.signature_role | escape }}</span>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="n-int__btn" href="{{ section.settings.button_link | default: '/pages/about' }}">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Niche Intro / About",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Photo", "info": "Leave empty to use the baked asset below." },
    { "type": "text", "id": "fallback_image", "label": "Fallback asset filename", "default": "niche-about.jpg", "info": "Used when no photo is uploaded above. e.g. niche-shopfront.jpg" },
    { "type": "text", "id": "badge_text", "label": "Floating badge text", "default": "Sunshine West's trusted local workshop" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Niche Automotive" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Proper Mechanical Work, Done Locally" },
    { "type": "textarea", "id": "body1", "label": "Paragraph 1", "default": "Niche Automotive is a Sunshine West workshop built on honest advice and quality workmanship. From routine log book servicing to full engine rebuilds, we look after all makes and models and treat every car like it's our own." },
    { "type": "textarea", "id": "body2", "label": "Paragraph 2", "default": "Alongside the workshop, we stock a growing range of quality second-hand parts, so whether you need a service booked in or a hard-to-find part tracked down, you're in the right place." },
    { "type": "text", "id": "points", "label": "Checklist (separate with | )", "default": "All makes & models | Fixed, upfront pricing | Warranty-safe servicing | Honest advice, every time" },
    { "type": "header", "content": "Signature + button" },
    { "type": "text", "id": "signature_name", "label": "Signature name", "default": "Gorgi" },
    { "type": "text", "id": "signature_role", "label": "Signature role", "default": "Niche Automotive" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "More About Us" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Section" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Padding top", "default": 92 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Padding bottom", "default": 92 }
  ],
  "presets": [ { "name": "Niche Intro / About" } ]
}
{% endschema %}
